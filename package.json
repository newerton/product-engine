{
  "name": "product-engine",
  "version": "0.0.1",
  "description": "A microservice with nest framework, typeorm, apache kafka and kubernetes.",
  "license": "MIT",
  "author": "Newerton Vargas de Araujo",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/unit/jest.config.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --silent --config ./test/unit/jest.config.ts",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/e2e/jest.config.ts",
    "prepare": "husky",
    "prisma": "prisma"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^7.8.0",
    "cache-manager": "^7.2.9",
    "cache-manager-redis-yet": "^5.1.5",
    "dotenv": "^17.4.2",
    "env-var": "^7.5.0",
    "kafkajs": "^2.2.4",
    "lightship": "^9.0.4",
    "pg": "^8.22.0",
    "redis": "^6.0.1",
    "rxjs": "^7.8.2",
    "swagger-themes": "^1.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.9.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "prisma": {
    "schema": "./src/_core/@shared/infrastructure/adapters/persistence/database/prisma/schema.prisma"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "js-yaml": "^4.3.0",
    "multer": "^2.1.2"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true,
    "prisma@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "@swc/core@1.15.43": true
  }
}
